# ── Turso Cloud Database (optional — leave blank to use local SQLite) ─────────
# Sign up free at https://turso.tech → create a DB → copy the URL and token
# Once set, ALL computers using this app share the same leads automatically.
#
# Setup (takes ~2 minutes):
#   1. Go to https://turso.tech and sign up
#   2. Click "Create Database" → name it "mapleadhunter"
#   3. Click the DB → "Generate Token" → copy both values below
TURSO_DATABASE_URL=libsql://mapleadhunter-yourname.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJ...

# ── Google Sheets Backup (optional) ──────────────────────────────────────────
# Lets you click "☁ Google Sheets" to export all leads to a spreadsheet.
#
# Setup (~5 minutes):
#   1. Go to https://console.cloud.google.com → create a project
#   2. Enable "Google Sheets API" for the project
#   3. Go to IAM → Service Accounts → Create → download JSON key
#   4. Create a blank Google Sheet → share it with the service account email
#   5. Paste the SHEET ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
#   6. Paste the entire service account JSON (single line) into GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...","client_email":"mapleadhunter@project.iam.gserviceaccount.com"}

# ── SMS via ADB ───────────────────────────────────────────────────────────────
SMS_GATEWAY=adb

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: Resend (alternative to Gmail)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Scraper settings (optional overrides) ─────────────────────────────────────
SCRAPE_MAX_PER_ZIP=30
SCRAPE_MIN_DELAY_MS=4000
SCRAPE_MAX_DELAY_MS=12000
