{
  "name": "mapleadhunter",
  "version": "1.0.0",
  "description": "Scrape Google Maps for no-website businesses and send outreach",
  "type": "module",
  "homepage": "https://github.com/benyamin-persia/mapleadhunter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benyamin-persia/mapleadhunter.git"
  },
  "bugs": {
    "url": "https://github.com/benyamin-persia/mapleadhunter/issues"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "scrape": "tsx src/cli/index.ts scrape",
    "export-leads": "tsx src/cli/index.ts export-leads",
    "send-sms": "tsx src/cli/index.ts send-sms",
    "send-email": "tsx src/cli/index.ts send-email",
    "web": "tsx src/server/index.ts",
    "setup-geo": "node scripts/setup-geo.mjs",
    "maps-login": "tsx scripts/maps-login.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "json2csv": "^6.0.0-alpha.2",
    "nodemailer": "^6.9.13",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/json2csv": "^5.0.7",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^6.4.15",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
